{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "es6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "importHelpers": true,
    "lib": ["dom", "es5", "scripthost", "es2015", "es2016", "es2017"],
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
